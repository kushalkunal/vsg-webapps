# ── Backend ────────────────────────────────────────────────────────────────
# Spring Boot base URL (no trailing slash).
# Local:      http://localhost:8080/api
# Production: https://your-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# ── Multi-Tenancy ───────────────────────────────────────────────────────────
# Default tenant slug for local development (optional).
# After login the tenant is resolved from the JWT payload automatically.
VITE_DEFAULT_TENANT_ID=

# ── Public Site ─────────────────────────────────────────────────────────────
# WhatsApp number for the floating button (country code + number, no +/spaces).
VITE_WHATSAPP_NUMBER=919521412485

